---
import Base from "../layouts/Base.astro";
import PostCard from "../components/PostCard.astro";
import PortableText from "@shared/PortableText.astro";
import { getPosts, getSiteSettings, getPageBySlug, getAllCategories } from "@shared/snapshot";
import { getSiteConfig } from "@shared/site-config";

const settings = getSiteSettings();
const config = getSiteConfig();
const posts = getPosts();
const recentPosts = posts.slice(0, 6);
const categories = getAllCategories();
const homePage = getPageBySlug("home");
---

<Base description={settings.tagline || homePage?.excerpt} currentPath="/">
  <div class="container">
    <section class="hero">
      <h1 class="hero__title">{settings.title}</h1>
      {settings.tagline && <p class="hero__tagline">{settings.tagline}</p>}

      {homePage && homePage.content.length > 0 && (
        <div class="hero__body">
          <PortableText value={homePage.content} />
        </div>
      )}

      <div class="hero__actions">
        {config.ctaLabel && config.ctaUrl && (
          <a class="btn btn--primary" href={config.ctaUrl}>{config.ctaLabel}</a>
        )}
        <a class="btn btn--ghost" href="/posts">
          See recent articles
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="8" x2="13" y2="8" /><polyline points="9,4 13,8 9,12" />
          </svg>
        </a>
      </div>
    </section>

    {categories.length > 0 && (
      <div class="category-bar">
        <a class="category-chip category-chip--active" href="/posts">All</a>
        {categories.map((cat) => (
          <a class="category-chip" href={`/category/${cat.slug}`}>{cat.label}</a>
        ))}
      </div>
    )}

    <div class="section-header">
      <h2 class="section-title">Recent articles <span class="section-count">({posts.length})</span></h2>
      {posts.length > 6 && (
        <a class="section-link" href="/posts">
          View all <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="6,3 11,8 6,13" /></svg>
        </a>
      )}
    </div>

    <div class="post-grid">
      {recentPosts.map((post, i) => (
        <PostCard post={post} eager={i < 2} />
      ))}
    </div>
  </div>
</Base>
