---
import Base from "../../layouts/Base.astro";
import PostCard from "../../components/PostCard.astro";
import { getAllCategories, getPostsByCategory } from "@shared/snapshot";

export function getStaticPaths() {
  return getAllCategories().map((cat) => ({ params: { slug: cat.slug }, props: { category: cat } }));
}
const { category } = Astro.props;
const posts = getPostsByCategory(category.slug);
const categories = getAllCategories();
---
<Base title={category.label}>
  <div class="container section">
    <h1 class="section-title">{category.label}</h1>
    <div class="filter-bar">
      <a href="/posts" class="filter-chip">All</a>
      {categories.map((cat) => <a href={`/category/${cat.slug}`} class:list={["filter-chip", { active: cat.slug === category.slug }]}>{cat.label}</a>)}
    </div>
    <div class="post-grid">{posts.map((post, i) => <PostCard post={post} eager={i < 2} />)}</div>
  </div>
</Base>
