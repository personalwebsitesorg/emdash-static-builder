---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getSiteSettings, getMenuItems, getPosts, getTheme } from "../lib/snapshot";
import { getSiteConfig } from "../lib/site-config";
import "../styles/base.css";
import "../../generated/fonts.css";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  publishedAt?: string | null;
  updatedAt?: string | null;
}

const settings = getSiteSettings();
const menuItems = getMenuItems();
const posts = getPosts();
const theme = getTheme();
const config = getSiteConfig();

const {
  title,
  description = settings.tagline || `${settings.title} — Articles and insights`,
  ogImage,
  ogType = "website",
  publishedAt,
  updatedAt,
} = Astro.props;

const documentTitle = title === "Home" ? settings.title : `${title} | ${settings.title}`;
const siteUrl = Astro.site ?? new URL(Astro.url.origin);
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();

let fontPreloads: string[] = [];
try {
  const fp = await import("../../generated/font-preloads.json");
  fontPreloads = fp.default || [];
} catch {}
---

<!doctype html>
<html lang="en" data-theme={theme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{documentTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="max-image-preview:large" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={documentTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={settings.title} />
    <meta property="og:type" content={ogType} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={documentTitle} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <!-- Article dates -->
    {publishedAt && <meta property="article:published_time" content={publishedAt} />}
    {updatedAt && <meta property="article:modified_time" content={updatedAt} />}

    <!-- Preload fonts -->
    {fontPreloads.map((href: string) => (
      <link rel="preload" href={href} as="font" type="font/woff2" crossorigin />
    ))}
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header settings={settings} menuItems={menuItems} config={config} />
    <main id="main">
      <slot />
    </main>
    <Footer settings={settings} menuItems={menuItems} recentPosts={posts} config={config} />
  </body>
</html>
