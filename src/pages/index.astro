---
import Base from "../layouts/Base.astro";
import PostCard from "../components/PostCard.astro";
import { getPosts, getSiteSettings, getPageBySlug } from "../lib/snapshot";

const settings = getSiteSettings();
const posts = getPosts();
const featuredPosts = posts.slice(0, 6);
const homePage = getPageBySlug("home");
---

<Base title="Home" description={settings.tagline}>
  <!-- Hero -->
  <section class="container section">
    <div class="hero">
      <h1 class="hero-title">{homePage?.title || settings.title}</h1>
      {settings.tagline && <p class="hero-subtitle">{settings.tagline}</p>}
    </div>
  </section>

  <!-- Featured posts -->
  <section class="container section">
    <div class="section-heading">
      <h2>Recent Articles</h2>
    </div>
    <div class="post-grid">
      {featuredPosts.map((post, i) => (
        <PostCard post={post} eager={i < 2} />
      ))}
    </div>
    {posts.length > 6 && (
      <div style="text-align: center; margin-top: 2rem;">
        <a href="/posts" class="view-all-link">View all articles &rarr;</a>
      </div>
    )}
  </section>
</Base>

<style>
  .hero {
    padding: 3rem 0 1rem;
    max-width: 680px;
  }
  .hero-title {
    font-size: clamp(2.25rem, 4vw, 3.25rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
  }
  .hero-subtitle {
    margin-top: 1rem;
    font-size: 1.125rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }
  .view-all-link {
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
</style>
