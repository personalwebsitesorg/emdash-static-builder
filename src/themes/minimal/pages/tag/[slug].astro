---
import Base from "../../layouts/Base.astro";
import { getAllTags, getPosts } from "@shared/snapshot";

export function getStaticPaths() {
  const tags = getAllTags();
  return tags.map((tag) => ({
    params: { slug: tag.slug },
    props: { tag },
  }));
}

const { tag } = Astro.props;
const posts = getPosts().filter((p) => p.tags.some((t) => t.slug === tag.slug));
---

<Base title={tag.label} description={`Posts tagged ${tag.label}`}>
  <div class="wrapper">
    <h1 class="section-title">{tag.label}</h1>

    <ul class="post-list">
      {posts.map((post) => {
        const date = post.publishedAt
          ? new Date(post.publishedAt).toLocaleDateString("en-US", {
              year: "numeric",
              month: "short",
              day: "numeric",
            })
          : "";
        return (
          <li>
            <a href={`/posts/${post.slug}`}>
              <time datetime={post.publishedAt || ""}>{date}</time>
              <span class="post-title">{post.title}</span>
            </a>
          </li>
        );
      })}
    </ul>

    {posts.length === 0 && <p style="color: var(--text-muted);">No posts with this tag yet.</p>}
  </div>
</Base>
