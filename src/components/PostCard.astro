---
import type { Post } from "../lib/snapshot";

interface Props {
  post: Post;
  eager?: boolean;
}

const { post, eager = false } = Astro.props;

const date = post.publishedAt
  ? new Date(post.publishedAt).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : null;

const primaryCategory = post.categories[0];
---

<article class="post-card">
  {post.featuredImage?.src && (
    <a href={`/posts/${post.slug}`} class="post-card-media">
      <img
        src={post.featuredImage.src}
        alt={post.featuredImage.alt || post.title}
        width={post.featuredImage.width || 600}
        height={post.featuredImage.height || 400}
        loading={eager ? "eager" : "lazy"}
        decoding="async"
      />
    </a>
  )}
  <div class="post-card-body">
    <div class="post-card-meta">
      {primaryCategory && (
        <a href={`/category/${primaryCategory.slug}`} class="post-card-category">{primaryCategory.label}</a>
      )}
      {date && <time datetime={post.publishedAt!}>{date}</time>}
      <span class="post-card-reading">{post.readingTime} min read</span>
    </div>
    <h3><a href={`/posts/${post.slug}`}>{post.title}</a></h3>
    {post.excerpt && <p class="post-card-excerpt">{post.excerpt}</p>}
  </div>
</article>
