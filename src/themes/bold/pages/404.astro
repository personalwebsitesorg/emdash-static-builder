---
import Base from "../layouts/Base.astro";
---
<Base title="Page Not Found">
  <div class="container section" style="text-align:center; padding: 8rem 1rem;">
    <h1 style="font-size: 6rem; color: var(--accent); text-shadow: 0 0 40px rgba(99,102,241,0.3);">404</h1>
    <p style="color: var(--text-secondary); margin-top: 1rem;">This page doesn't exist.</p>
    <p style="margin-top: 1rem;"><a href="/" style="color: var(--accent);">Go back home</a></p>
  </div>
</Base>
