---
import Base from "../layouts/Base.astro";
import { getPosts, getSiteSettings } from "@shared/snapshot";

const settings = getSiteSettings();
const posts = getPosts();
---

<Base title="Home" description={settings.tagline}>
  <div class="wrapper">
    <h1 class="home-title">{settings.title}</h1>
    {settings.tagline && <p class="home-description">{settings.tagline}</p>}

    <ul class="post-list">
      {posts.map((post) => {
        const date = post.publishedAt
          ? new Date(post.publishedAt).toLocaleDateString("en-US", {
              year: "numeric",
              month: "short",
              day: "numeric",
            })
          : "";
        return (
          <li>
            <a href={`/posts/${post.slug}`}>
              <time datetime={post.publishedAt || ""}>{date}</time>
              <span class="post-title">{post.title}</span>
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</Base>
