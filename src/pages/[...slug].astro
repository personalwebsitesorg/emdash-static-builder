---
import Base from "../layouts/Base.astro";
import PortableText from "../components/PortableText.astro";
import { getPages } from "../lib/snapshot";

export function getStaticPaths() {
  const reserved = new Set(["home", "blog", "posts", "articles"]);
  const pages = getPages();
  return pages
    .filter((page) => !reserved.has(page.slug))
    .map((page) => ({
      params: { slug: page.slug },
      props: { page },
    }));
}

const { page } = Astro.props;
---

<Base title={page.title} description={page.excerpt} ogImage={page.featuredImage?.src}>
  <section class="container section">
    <article class="prose">
      <h1>{page.title}</h1>
      {page.featuredImage?.src && (
        <figure class="content-image">
          <img
            src={page.featuredImage.src}
            alt={page.featuredImage.alt || page.title}
            width={page.featuredImage.width || 1200}
            height={page.featuredImage.height || 800}
            loading="eager"
            decoding="async"
          />
        </figure>
      )}
      <PortableText value={page.content} />
    </article>
  </section>
</Base>
