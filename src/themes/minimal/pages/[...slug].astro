---
import Base from "../layouts/Base.astro";
import PortableText from "@shared/PortableText.astro";
import { getPages } from "@shared/snapshot";

export function getStaticPaths() {
  const reserved = new Set(["home", "blog", "posts", "articles"]);
  return getPages().filter((p) => !reserved.has(p.slug)).map((p) => ({ params: { slug: p.slug }, props: { page: p } }));
}
const { page } = Astro.props;
---
<Base title={page.title} description={page.excerpt} ogImage={page.featuredImage?.src}>
  <div class="container section">
    <article class="prose">
      <h1>{page.title}</h1>
      {page.featuredImage?.src && <figure class="content-image"><img src={page.featuredImage.src} alt={page.featuredImage.alt || page.title} width="760" height="475" loading="eager" decoding="async" fetchpriority="high" sizes="(max-width: 640px) 100vw, 760px" /></figure>}
      <PortableText value={page.content} />
    </article>
  </div>
</Base>
