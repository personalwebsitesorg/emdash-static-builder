---
import type { SiteSettings, MenuItem, Post } from "../lib/snapshot";
import type { SiteConfig } from "../lib/site-config";

interface Props {
  settings: SiteSettings;
  menuItems: MenuItem[];
  recentPosts: Post[];
  config: SiteConfig;
}

const { settings, menuItems, recentPosts, config } = Astro.props;
const year = new Date().getFullYear();
const displayName = config.copyrightName || settings.title;
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <strong class="footer-name">{settings.title}</strong>
      {settings.tagline && <p class="footer-tagline">{settings.tagline}</p>}
      {config.footerBlurb && <p class="footer-blurb">{config.footerBlurb}</p>}

      {config.social.length > 0 && (
        <div class="footer-social">
          {config.social.map((s) => (
            <a
              href={s.url}
              class="social-link"
              aria-label={s.label}
              target={s.platform === "email" ? undefined : "_blank"}
              rel={s.platform === "email" ? undefined : "noopener noreferrer"}
            >
              <Fragment set:html={s.icon} />
            </a>
          ))}
        </div>
      )}
    </div>

    <div class="footer-col">
      <p class="footer-heading">Navigation</p>
      <ul>
        {menuItems.map((item) => (
          <li><a href={item.url}>{item.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="footer-col">
      <p class="footer-heading">Recent Articles</p>
      <ul>
        {recentPosts.slice(0, 4).map((post) => (
          <li><a href={`/posts/${post.slug}`}>{post.title}</a></li>
        ))}
      </ul>
    </div>
  </div>

  <div class="container footer-bottom">
    <p>&copy; {year} {displayName}. All rights reserved.</p>
  </div>
</footer>
