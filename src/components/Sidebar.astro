---
import type { Post, Taxonomy } from "../lib/snapshot";

interface Props {
  recentPosts: Post[];
  categories: Taxonomy[];
  tags: Taxonomy[];
}

const { recentPosts, categories, tags } = Astro.props;
---

<aside class="sidebar">
  {categories.length > 0 && (
    <div class="sidebar-section">
      <h3 class="sidebar-heading">Categories</h3>
      <ul class="sidebar-list">
        {categories.map((cat) => (
          <li><a href={`/category/${cat.slug}`}>{cat.label}</a></li>
        ))}
      </ul>
    </div>
  )}

  <div class="sidebar-section">
    <h3 class="sidebar-heading">Recent Articles</h3>
    <ul class="sidebar-list">
      {recentPosts.slice(0, 5).map((post) => (
        <li><a href={`/posts/${post.slug}`}>{post.title}</a></li>
      ))}
    </ul>
  </div>

  {tags.length > 0 && (
    <div class="sidebar-section">
      <h3 class="sidebar-heading">Tags</h3>
      <div class="tag-cloud">
        {tags.map((tag) => (
          <a href={`/tag/${tag.slug}`} class="tag-pill">{tag.label}</a>
        ))}
      </div>
    </div>
  )}
</aside>
